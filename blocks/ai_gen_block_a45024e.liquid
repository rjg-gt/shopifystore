{% doc %}
  @prompt
    Create a simple sticky footer that stays fixed at the bottom of the page. Include basic footer elements like copyright text, social media links, and navigation links. The footer should remain visible at the bottom of the viewport as users scroll.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-sticky-footer-{{ ai_gen_id }} {
    position: fixed;
    bottom: 0;
    left: 0;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    color: {{ block.settings.text_color }};
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    z-index: 999;
    box-shadow: 0 -2px 10px rgba(0, 0, 0, {{ block.settings.shadow_opacity }});
    display: block;
  }

  .ai-sticky-footer__container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
  }

  .ai-sticky-footer__copyright-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    margin: 0;
  }

  .ai-sticky-footer__nav-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.nav_gap }}px;
    align-items: center;
    flex-wrap: wrap;
  }

  .ai-sticky-footer__nav-link-{{ ai_gen_id }} {
    color: {{ block.settings.link_color }};
    text-decoration: none;
    font-size: {{ block.settings.text_size }}px;
    transition: color 0.3s ease;
  }

  .ai-sticky-footer__nav-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.link_hover_color }};
  }

  .ai-sticky-footer__social-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.social_gap }}px;
    align-items: center;
  }

  .ai-sticky-footer__social-link-{{ ai_gen_id }} {
    color: {{ block.settings.social_icon_color }};
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
    width: {{ block.settings.social_icon_size }}px;
    height: {{ block.settings.social_icon_size }}px;
    transition: color 0.3s ease;
  }

  .ai-sticky-footer__social-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.social_icon_hover_color }};
  }

  .ai-sticky-footer__social-link-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
  }

  @media screen and (max-width: 749px) {
    .ai-sticky-footer__container-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 15px;
    }

    .ai-sticky-footer__nav-{{ ai_gen_id }} {
      justify-content: center;
    }
  }
{% endstyle %}

<sticky-footer-{{ ai_gen_id }} class="ai-sticky-footer-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-sticky-footer__container-{{ ai_gen_id }}">
    <div class="ai-sticky-footer__copyright-{{ ai_gen_id }}">
      {{ block.settings.copyright_text }}
    </div>

    {% if block.settings.show_navigation %}
      <nav class="ai-sticky-footer__nav-{{ ai_gen_id }}">
        {% if block.settings.nav_link_1_text != blank and block.settings.nav_link_1_url != blank %}
          <a href="{{ block.settings.nav_link_1_url }}" class="ai-sticky-footer__nav-link-{{ ai_gen_id }}">
            {{ block.settings.nav_link_1_text }}
          </a>
        {% endif %}
        {% if block.settings.nav_link_2_text != blank and block.settings.nav_link_2_url != blank %}
          <a href="{{ block.settings.nav_link_2_url }}" class="ai-sticky-footer__nav-link-{{ ai_gen_id }}">
            {{ block.settings.nav_link_2_text }}
          </a>
        {% endif %}
        {% if block.settings.nav_link_3_text != blank and block.settings.nav_link_3_url != blank %}
          <a href="{{ block.settings.nav_link_3_url }}" class="ai-sticky-footer__nav-link-{{ ai_gen_id }}">
            {{ block.settings.nav_link_3_text }}
          </a>
        {% endif %}
        {% if block.settings.nav_link_4_text != blank and block.settings.nav_link_4_url != blank %}
          <a href="{{ block.settings.nav_link_4_url }}" class="ai-sticky-footer__nav-link-{{ ai_gen_id }}">
            {{ block.settings.nav_link_4_text }}
          </a>
        {% endif %}
      </nav>
    {% endif %}

    {% if block.settings.show_social %}
      <div class="ai-sticky-footer__social-{{ ai_gen_id }}">
        {% if block.settings.facebook_url != blank %}
          <a href="{{ block.settings.facebook_url }}" class="ai-sticky-footer__social-link-{{ ai_gen_id }}" aria-label="Facebook" target="_blank" rel="noopener">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
        {% endif %}
        {% if block.settings.instagram_url != blank %}
          <a href="{{ block.settings.instagram_url }}" class="ai-sticky-footer__social-link-{{ ai_gen_id }}" aria-label="Instagram" target="_blank" rel="noopener">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
        {% endif %}
        {% if block.settings.twitter_url != blank %}
          <a href="{{ block.settings.twitter_url }}" class="ai-sticky-footer__social-link-{{ ai_gen_id }}" aria-label="Twitter" target="_blank" rel="noopener">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
              <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
            </svg>
          </a>
        {% endif %}
        {% if block.settings.youtube_url != blank %}
          <a href="{{ block.settings.youtube_url }}" class="ai-sticky-footer__social-link-{{ ai_gen_id }}" aria-label="YouTube" target="_blank" rel="noopener">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </a>
        {% endif %}
      </div>
    {% endif %}
  </div>
</sticky-footer-{{ ai_gen_id }}>

<script>
  (function() {
    class StickyFooter{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.adjustBodyPadding();
        window.addEventListener('resize', this.adjustBodyPadding.bind(this));
      }

      adjustBodyPadding() {
        const footerHeight = this.offsetHeight;
        document.body.style.paddingBottom = footerHeight + 'px';
      }

      disconnectedCallback() {
        document.body.style.paddingBottom = '';
        window.removeEventListener('resize', this.adjustBodyPadding.bind(this));
      }
    }

    customElements.define('sticky-footer-{{ ai_gen_id }}', StickyFooter{{ ai_gen_id }});
  })();
</script>

